GEMINI_API_KEY=your_gemini_key_here
# Optional: comma-separated pool of Gemini keys to rotate through (only useful
# if the keys are under genuinely separate Google Cloud projects with
# independent quota).
# GEMINI_API_KEYS=key_one,key_two,key_three

# Optional fallback: if all Gemini keys are exhausted, automatically fall
# back to Groq (much higher free-tier limits). Get a free key at
# https://console.groq.com
# GROQ_API_KEY=your_groq_key_here
